# 1. Get an API key from https://console.anthropic.com  ->  Settings  ->  API Keys
# 2. Copy this file to a new file named ".env" (in this same backend/ folder)
# 3. Paste your key after the = sign, with no quotes and no spaces.
ANTHROPIC_API_KEY=
NCBI_API_KEY=

# Optional. LOG_LEVEL=DEBUG logs full answers + abstracts (default INFO).
# CONCISE_MODE=false lets answers run longer / more technical (default true).
LOG_LEVEL=INFO
CONCISE_MODE=true